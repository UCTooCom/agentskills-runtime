# AgentSkills Runtime Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Runtime Configuration
# ===========================================
# Log level: error | info | debug | trace
# Default: info
LOG_LEVEL=info

# ===========================================
# Server Configuration
# ===========================================
# Server listening port
# Default: 8080
# For production HTTPS, use standard port 443
# For development, use custom port like 8443
PORT=8080

# Server bind address
# Default: 0.0.0.0 (all interfaces)
# For local development only: 127.0.0.1
HOST=0.0.0.0

# Backend URL (determines HTTP/HTTPS mode)
# If starts with https://, HTTPS mode is enabled
# If starts with http:// or not set, HTTP mode is used
# BACKEND_URL=http://localhost:8080
# BACKEND_URL=https://your-domain.com

# SSL Certificate Configuration (for HTTPS mode)
# Paths to SSL certificate and private key files
# Supports both relative and absolute paths
# Relative paths are relative to the executable directory
# Default: ssl/server.crt and ssl/server.key
# CERT_FILE_NAME=ssl/server.crt
# KEY_FILE_NAME=ssl/server.key

# Examples for different certificate locations:
# Relative path (recommended for development)
# CERT_FILE_NAME=ssl/server.crt
# KEY_FILE_NAME=ssl/server.key

# Absolute path (recommended for production)
# CERT_FILE_NAME=/etc/ssl/certs/your-domain.com.crt
# KEY_FILE_NAME=/etc/ssl/private/your-domain.com.key

# Windows absolute path
# CERT_FILE_NAME=C:/ssl/server.crt
# KEY_FILE_NAME=C:/ssl/server.key

# ===========================================
# Public Repository Search API Tokens (Optional)
# ===========================================
# These tokens are OPTIONAL. Without tokens, search still works but with lower rate limits.
# 
# Rate Limits:
# - GitHub: 10 requests/min without token, 30 requests/min with token
# - Gitee: Limited without token, higher with token
# - AtomGit: Limited without token, higher with token

# GitHub Personal Access Token
# Get your token: https://github.com/settings/tokens
# Required scopes: public_repo (for searching public repositories)
# Note: GitHub uses "Authorization: token" header
# IMPORTANT: Uncomment and set your token, or leave commented for anonymous access
# GITHUB_TOKEN=your_github_personal_access_token

# Gitee Private Token
# Get your token: https://gitee.com/profile/personal_access_tokens
# Note: Gitee uses access_token URL parameter
# IMPORTANT: Uncomment and set your token, or leave commented for anonymous access
# GITEE_TOKEN=your_gitee_private_token

# AtomGit Access Token
# Get your token: https://atomgit.com/-/profile/personal_access_tokens
# Note: AtomGit uses access_token URL parameter (Gitee-compatible API)
# IMPORTANT: Uncomment and set your token, or leave commented for anonymous access
# ATOMGIT_TOKEN=your_atomgit_access_token

# ===========================================
# LLM Model Configuration (Optional)
# ===========================================
# Configure your preferred LLM provider for AI-powered features

# Model Provider: openai | dashscope | stepfun | deepseek | sophnet | maas | zhipuai | siliconflow | google | moonshot | ark | openrouter | ollama | llamacpp
# MODEL_PROVIDER=sophnet
# MODEL_NAME=MiniMax-M2.5
MODEL_CONFIG=sophnet:MiniMax-M2.5

# ===========================================
# AI Model Provider Configurations
# ===========================================

# OpenAI (GPT-4, GPT-3.5, etc.)
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# StepFun (阶跃星辰)
# STEPFUN_API_KEY=your_stepfun_api_key
# STEPFUN_BASE_URL=https://api.stepfun.com/v1

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Sophnet
SOPHNET_BASE_URL=https://www.sophnet.com/api/open-apis/v1
SOPHNET_API_KEY=your_sophnet_api_key

# 华为云 MaaS (ModelArts Studio)
# MAAS_API_KEY=your_maas_api_key
# MAAS_BASE_URL=https://api.modelarts-maas.com/v2
# MAAS_MODEL_NAME=qwen3-coder-480b-a35b-instruct

# 智谱 AI (ZhipuAI)
# ZHIPU_API_KEY=your_zhipuai_api_key
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 阿里云 DashScope
# DASHSCOPE_API_KEY=your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# SiliconFlow
# SILICONFLOW_API_KEY=your_siliconflow_api_key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Google Gemini
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Moonshot (月之暗面)
# MOONSHOT_API_KEY=your_moonshot_api_key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# 火山引擎 ARK (字节跳动)
# ARK_API_KEY=your_ark_api_key
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenRouter
# OPENROUTER_API_KEY=your_openrouter_api_key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (本地部署)
# OLLAMA_BASE_URL=http://localhost:11434

# LLama.cpp (本地推理)
# LLAMACPP_BASE_URL=http://localhost:8080

# ===========================================
# Skill Installation Configuration
# ===========================================
# Path where skills are installed and loaded from
# This single configuration controls both:
#   - Where new skills are installed (via API/CLI)
#   - Where the runtime loads skills from
#
# Priority: 
#   1. SKILL_INSTALL_PATH environment variable
#   2. Default: ./skills (relative to runtime working directory)
#
# Examples:
#   SKILL_INSTALL_PATH=./skills                    # Relative path (recommended)
#   SKILL_INSTALL_PATH=/opt/agentskills/skills     # Absolute path (Linux/macOS)
#   SKILL_INSTALL_PATH=C:/agentskills/skills       # Absolute path (Windows)
#
# Note: When using JavaScript SDK, the default working directory is:
#   node_modules/@opencangjie/skills/runtime/<platform>-<arch>/release/
# To install skills in your project root, use an absolute path or navigate 
# to your project directory before starting the runtime.
SKILL_INSTALL_PATH=./skills
# Progressive skill loading configuration
PROGRESSIVE_SKILL_LOADING_ENABLED=true
# GitHub API Token (用于搜索 GitHub 仓库)
GITHUB_TOKEN=ghp_your_github_token

# Gitee API Token (用于搜索 Gitee 仓库)
GITEE_TOKEN=your_gitee_token

# AtomGit API Token (用于搜索 AtomGit 仓库)
ATOMGIT_TOKEN=your_atomgit_token

# Firecrawl Configuration
# Firecrawl API Key (用于网络搜索和内容抓取)
# 获取方式: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Firecrawl API URL (可选，用于私有化部署)
# 默认使用 Firecrawl 云服务: https://api.firecrawl.dev
# 私有化部署示例: http://localhost:3002
FIRECRAWL_API_URL=https://api.firecrawl.dev

# Firecrawl 默认搜索限制
# 默认返回的搜索结果数量
FIRECRAWL_DEFAULT_LIMIT=10

# ============================================
# ORM Database Configuration
# ============================================
# 数据库驱动配置
# DATABASE_URL=postgresql://postgres:password@localhost:5432/uctoo
orm_drivers=opengauss
orm_defaultDriver=opengauss
# orm_connectionUrl=postgresql://postgres:password@localhost:5432/uctoo

# PostgreSQL 驱动特定配置
# opengauss_orm_connectionUrl=postgresql://postgres:password@localhost:5432/uctoo

# ============================================
# Token Configuration
# ============================================
# Token Info
# Access Token 有效期（秒）
# 20 DAYS: 1728000 Sec
ACCESS_TOKEN_VALIDITY_SEC=1728000

# JWT 密钥
AUTH_CORE_SECRET=your_secret_key

# Refresh Token 有效期（秒）
# 70 DAYS: 6048000 Sec
REFRESH_TOKEN_VALIDITY_SEC=6048000

# Token 签发者
TOKEN_ISSUER=yourapi.example.com

# Token 受众
TOKEN_AUDIENCE=example.com