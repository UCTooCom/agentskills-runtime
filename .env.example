# CangjieMagic Framework Configuration
# Examples directory configuration
EXAMPLES_DIR=D:/UCT/projects/miniapp/uctoo/Delivery/uctoo-admin/apps/agentskills-runtime/src/examples

# UCToo API Skill directory
UCTOO_API_SKILL_DIR=D:/UCT/projects/miniapp/uctoo/Delivery/uctoo-admin/apps/agentskills-runtime/src/examples/uctoo_api_skill

# Progressive skill loading configuration
PROGRESSIVE_SKILL_LOADING_ENABLED=true
SKILL_BASE_DIRECTORY=${EXAMPLES_DIR}

# Model Configuration
# 使用华为云 MaaS 大模型服务
MODEL_PROVIDER=maas
MODEL_NAME=qwen3-coder-480b-a35b-instruct
MODEL_CONFIG=maas:${MODEL_NAME}

# Skill Installation Directory Configuration
# If not specified, defaults to ./skills directory
# SKILL_INSTALL_PATH=./examples

# API Keys and credentials (automatically matched with model configuration)
# STEPFUN configuration
#STEPFUN_API_KEY=your_stepfun_api_key_here
#STEPFUN_BASE_URL=https://api.stepfun.com/v1

# 华为云 MaaS (ModelArts Studio) 配置
# API文档: https://support.huaweicloud.com/usermanual-maas/usermanual_maas_0021.html
# API地址: https://api.modelarts-maas.com/v2/chat/completions
# 鉴权请求头: "Authorization": "Bearer $MAAS_API_KEY"
MAAS_API_KEY=your_api_key_here
MAAS_BASE_URL=https://api.modelarts-maas.com/v2
# MaaS 支持的模型 (使用小写格式):
# - qwen3-coder-480b-a35b-instruct (代码能力强)
# - qwen3-235b-a22b
# - qwen3-32b-32k
# - qwen3-30b-a3b
MAAS_MODEL_NAME=qwen3-coder-480b-a35b-instruct


# DASHSCOPE configuration (for fallback or alternative use)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
