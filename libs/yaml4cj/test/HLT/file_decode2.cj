import yaml4cj.yaml.*
import std.env.*
import std.fs.*
import stdx.encoding.json.*
import std.unittest.*
import std.unittest.testmacro.*

//func decode(data: Array<UInt8>): JsonValue
//func decode(data: Array<UInt8>, strict: Bool): JsonValue
//func encode(input: JsonValue): Array<UInt8>
@Test
class Yaml_Decode {
    @TestCase
    func yaml_Decode56(): Unit {
        for (i in 1..211) {
            let pathname1: String = "json/${i}.json"
            println(pathname1)
            var fs1: File = File(pathname1, ReadWrite)
            var res1: Array<UInt8> = File.readFrom(pathname1)
            var expect: String = String.fromUtf8(res1)
            println(expect)
            let pathname: String = "yaml/${i}.yaml"
            println(pathname)
            var fs: File = File(pathname, ReadWrite)
            var res: Array<UInt8> = File.readFrom(pathname)
            var jv = decode(res)
            try {
                @Assert(jv.toJsonString().replace(" ","").replace("\r","").replace("\\u0026", "&"),expect.toString().replace(" ","").replace("\r",""))
                println("${i}对比成功")
            } catch (e: Exception) {
                println("${i}对比失败")
            }
        }
    }
}
