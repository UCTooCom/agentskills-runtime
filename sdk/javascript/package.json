{
  "name": "@opencangjie/skills",
  "version": "1.0.1",
  "description": "JavaScript/TypeScript SDK for AgentSkills Runtime - Install, manage, and execute AI agent skills with built-in runtime support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "skills": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    "README.md",
    "README_cn.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "agent-skills",
    "skills",
    "ai",
    "agent",
    "runtime",
    "cli",
    "uctoo",
    "cangjiemagic",
    "mcp",
    "llm-tools",
    "skill-runtime",
    "ai-agent-tools"
  ],
  "author": "OpenCangJie Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://atomgit.com/uctoo/agentskills-runtime.git"
  },
  "homepage": "https://atomgit.com/uctoo/agentskills-runtime",
  "bugs": {
    "url": "https://atomgit.com/uctoo/agentskills-runtime/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "conf": "^11.0.0",
    "execa": "^8.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.0",
    "tar": "^6.2.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.2",
    "@types/tar": "^6.1.13",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@types/node": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  },
  "runtime": {
    "version": "0.0.20",
    "downloadUrl": "https://atomgit.com/UCToo/agentskills-runtime/releases",
    "platforms": {
      "win32-x64": "agentskills-runtime-win-x64.tar.gz",
      "darwin-x64": "agentskills-runtime-darwin-x64.tar.gz",
      "darwin-arm64": "agentskills-runtime-darwin-arm64.tar.gz",
      "linux-x64": "agentskills-runtime-linux-x64.tar.gz",
      "linux-arm64": "agentskills-runtime-linux-arm64.tar.gz"
    }
  }
}
