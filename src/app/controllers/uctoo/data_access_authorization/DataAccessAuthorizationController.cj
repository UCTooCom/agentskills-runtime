            }
            res.status(200).json("{\"currentPage\":${pageNum},\"totalCount\":${total},\"totalPage\":${totalPage},\"skip\":${skipNum},\"data_access_authorizations\":[${entitiesJson}]}")
        } catch (e: Exception) {
