# uctoo_api_skill 环境变量配置示例
# 复制此文件为 .env 并根据需要修改配置

# uctoo 后端 API 基础 URL
# 这是必需的环境变量，用于指定 API 服务器地址
BACKEND_URL=https://javatoarktsapi.uctoo.com

# 日志级别
# 可选值: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# API 请求超时时间（毫秒）
DEFAULT_TIMEOUT=10000

# 可选：API Key（如果需要）
# UCTOO_API_KEY=your_api_key_here

# 可选：StepFun API 配置
# STEPFUN_API_KEY=your_stepfun_api_key
# STEPFUN_BASE_URL=https://api.stepfun.com
